@page "/"

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits AsyncComponentBase
@attribute [Authorize]

@using Keepi.Core
@using Keepi.Core.Entries
@using Keepi.Core.InvoiceItems
@using Keepi.Core.Projects
@using Keepi.Core.UserInvoiceItemCustomizations
@using Keepi.Core.UserProjects
@using Keepi.Core.Users
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Diagnostics
@using System.Text.RegularExpressions
@using System.Text
@using System.ComponentModel.DataAnnotations

<PageTitle>Home</PageTitle>

<FluentEditForm Model="Model" OnSubmit="Submit" FormName="WeekUserEntries">
    <DataAnnotationsValidator />
    
    <FluentGrid Spacing="1" Style="max-width:1000px; min-width:900px;">
        @* Header *@
        <FluentGridItem xs="4" Style="max-width:12rem;"></FluentGridItem>

        @foreach (var date in Model!.Dates)
        {
            <FluentGridItem xs="1" style="text-align:center;">
                @date.ToString(format: "MM-dd")
            </FluentGridItem>
        }

        <FluentGridItem xs="1"></FluentGridItem>

        @* Body *@
        @foreach(var row in Model!.Rows)
        {
            <FluentGridItem xs="4" Style="max-width:12rem; display: flex; flex-direction: column; justify-content: center;">
                <span>@row.InvoiceItemName</span>
            </FluentGridItem>

            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.MondayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>
            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.TuesdayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>
            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.WednesdayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>
            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.ThursdayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>
            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.FridayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>
            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.SaturdayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>
            <FluentGridItem xs="1">
                <FluentTextField @bind-value="@row.SundayMinutes" Disabled="@(!row.Enabled)" />
            </FluentGridItem>

            <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        }

        @* Footer *@
        <FluentGridItem xs="4" Style="max-width:12rem;"></FluentGridItem>

        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
        <FluentGridItem xs="1" style="text-align:center;">99u99m</FluentGridItem>
    </FluentGrid>

    <FluentButton Type="ButtonType.Submit">Submit</FluentButton>
</FluentEditForm>

@code {
    [Inject]
    protected IServiceProvider ServiceProvider { get; set; } = default!;
    [Inject]
    protected NavigationManager NavigationManager { get; set; } = default!;
    [Inject]
    protected ILogger<Home> Logger { get; set; } = default!;

    [SupplyParameterFromForm(Name = "WeekUserEntries")]
    private WeekUserEntries? Model { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!RendererInfo.IsInteractive)
        {
            // For some reason this page is still pre rendered despite
            // prerendering being turned off, see the rendermode at the top.
            return;
        }

        if (Model == null)
        {
            Model = await CreateModel(serviceProvider: ServiceProvider, logger: Logger, cancellationToken: ComponentCancellationToken);
        }
    }
    private static async Task<WeekUserEntries> CreateModel(
        IServiceProvider serviceProvider,
        ILogger<Home> logger,
        CancellationToken cancellationToken)
    {
        using var scope = serviceProvider.CreateScope();

        var getUserProjectsUseCase = scope.ServiceProvider.GetRequiredService<IGetUserProjectsUseCase>();
        var userProjectsResult = await getUserProjectsUseCase.Execute(cancellationToken: cancellationToken);
        if (!userProjectsResult.TrySuccess(out var userProjects, out var getUserProjectsError))
        {
            logger.LogError("Failed to retrieve user projects due to error {Error}", getUserProjectsError);
            return new();
        }
        var invoiceItems = userProjects.Projects
            .SelectMany(p => p.InvoiceItems.Select(i => new InvoiceItem(Id: i.Id, Name: i.Name.Value, ProjectId: p.Id, ProjectName: p.Name.Value, ProjectEnabled: p.Enabled, Ordinal: i.Customization.Ordinal)))
            .OrderBy(i => !i.ProjectEnabled).ThenBy(i => i.Ordinal).ThenBy(i => i.Name)
            .ToArray();

        var currentWeek = Week.Today;

        var getUserEntriesForWeekUseCase = scope.ServiceProvider.GetRequiredService<IGetUserEntriesForWeekUseCase>();
        var userEntriesResult = await getUserEntriesForWeekUseCase.Execute(week: currentWeek, cancellationToken: cancellationToken);
        if (!userEntriesResult.TrySuccess(out var userEntries, out var getUserEntriesError))
        {
            logger.LogError("Failed to retrieve user entries due to error {Error}", getUserEntriesError);
            return new();
        }

        var inputRows = new List<WeekInputRow>(capacity: invoiceItems.Length);
        foreach (var invoiceItem in invoiceItems)
        {
            inputRows.Add(new()
            {
                InvoiceItemId = invoiceItem.Id.Value,
                InvoiceItemName = invoiceItem.Name,
                Enabled = invoiceItem.ProjectEnabled,

                MondayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Monday, invoiceItemId: invoiceItem.Id),
                TuesdayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Tuesday, invoiceItemId: invoiceItem.Id),
                WednesdayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Wednesday, invoiceItemId: invoiceItem.Id),
                ThursdayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Thursday, invoiceItemId: invoiceItem.Id),
                FridayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Friday, invoiceItemId: invoiceItem.Id),
                SaturdayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Saturday, invoiceItemId: invoiceItem.Id),
                SundayMinutes = GetFormattedMinutesOrEmpty(day: userEntries.Sunday, invoiceItemId: invoiceItem.Id),
            });
        }
        Debug.Assert(inputRows.Count == invoiceItems.Length);

        return new()
        {
            Dates = currentWeek.ToDates(),
            Rows = inputRows.ToArray(),
        };
    }

    private sealed record InvoiceItem(InvoiceItemId Id, string Name, ProjectId ProjectId, string ProjectName, bool ProjectEnabled, UserInvoiceITemCustomizationOrdinal Ordinal);

    private sealed class WeekUserEntries
    {
        public DateOnly[] Dates { get; set; } = [];
        public WeekInputRow[] Rows { get; set; } = [];
    }

    private sealed class WeekInputRow
    {
        private const string minutesRegex = "^([0-9]+u)?([0-9]+m)?$";

        public int InvoiceItemId { get; set; }
        public string InvoiceItemName { get; set; } = string.Empty;
        public bool Enabled { get; set; } = false;

        [RegularExpression(pattern: minutesRegex)]
        public string MondayMinutes { get; set; } = string.Empty;
        [RegularExpression(pattern: minutesRegex)]
        public string TuesdayMinutes { get; set; } = string.Empty;
        [RegularExpression(pattern: minutesRegex)]
        public string WednesdayMinutes { get; set; } = string.Empty;
        [RegularExpression(pattern: minutesRegex)]
        public string ThursdayMinutes { get; set; } = string.Empty;
        [RegularExpression(pattern: minutesRegex)]
        public string FridayMinutes { get; set; } = string.Empty;
        [RegularExpression(pattern: minutesRegex)]
        public string SaturdayMinutes { get; set; } = string.Empty;
        [RegularExpression(pattern: minutesRegex)]
        public string SundayMinutes { get; set; } = string.Empty;
    }

    private static string GetFormattedMinutesOrEmpty(GetUserEntriesForWeekUseCaseOutputDay day, InvoiceItemId invoiceItemId)
    {
        var minutes = day.Entries.FirstOrDefault(e => e.InvoiceItemId == invoiceItemId)?.Minutes.Value ?? 0;
        if (minutes <= 0)
        {
            return string.Empty;
        }

        var result = new StringBuilder();
        var hours = minutes / 60;
        if (hours > 0)
        {
            result.Append(hours);
            result.Append('u');
        }

        var remainingMinutes = minutes - (hours * 60);
        if (remainingMinutes > 0)
        {
            result.Append(remainingMinutes);
            result.Append('m');
        }

        return result.ToString();
    }

    private void Submit(EditContext editContext)
    {
        if (editContext.Validate()) {
            Logger.LogInformation("Valid week user entries");
        } else {
            Logger.LogInformation("Invalid week user entries");
        }
    }
}
