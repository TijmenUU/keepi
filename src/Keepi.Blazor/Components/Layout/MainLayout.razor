@using Microsoft.FluentUI.AspNetCore.Components
@using static Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20
@inherits LayoutComponentBase

<FluentMainLayout>
    <Header>
        <FluentSpacer />
        <FluentAnchor Href="https://learn.microsoft.com/aspnet/core/" Target="_blank" Appearance="Appearance.Hypertext">About</FluentAnchor>
    </Header>

    <Body>
        @Body
    </Body>

    <NavMenuContent>
        <FluentNavLink Icon="@(new Home())" Href="/" Match="NavLinkMatch.All">Home</FluentNavLink>
        <FluentNavLink Icon="@(new Calculator())" Href="/counter">Counter</FluentNavLink>
        <FluentNavLink Icon="@(new WeatherPartlyCloudyDay())" Href="/weather">Weather</FluentNavLink>
    </NavMenuContent>
</FluentMainLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />
